PORT=8000
LOG_LEVEL=INFO

INSPECTION_SERVICE_URL=http://localhost:3000
INTERNAL_API_KEY=replace-me-with-a-shared-secret

# Phase 1: optimizer returns a dry-run plan only.
DEFAULT_DRY_RUN=true

# HTTP client tuning
INSPECTION_SERVICE_TIMEOUT_SEC=30
INSPECTION_SERVICE_PAGE_SIZE=200

# Solver tuning
SOLVER_TIME_SEC=30
W_ASSIGN=1000
W_URGENCY=10
# Penalty per km of distance between request and inspector. Stays well below
# W_ASSIGN so distance can never cause us to drop an assignment.
W_DISTANCE=5

# Inspection request status id for PENDING (matches InspectionRequestStatusId.PENDING)
PENDING_STATUS_ID=insp-req-status01
